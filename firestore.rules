rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function adminUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && adminUserDoc().data.role == 'admin'
        && (
          !('isActive' in adminUserDoc().data)
          || adminUserDoc().data.isActive == true
        );
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    match /vehicles/{vehicleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /search_logs/{logId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Aggregate counters only — customers must update on search/payment without signing in.
    match /stats/{docId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }
  }
}
